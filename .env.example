OPENWEBUI_BASE_URL=http://localhost:3000
OPENWEBUI_API_KEY=changeme
POLL_INTERVAL_SECONDS=30
EXPORTER_PORT=9090

# Token prices live in pricing.py (a per-model rate table, $ per 1M tokens).
# It ships with MOCK prices for the local Ollama models so the cost panels have
# data to show. Point MODEL_PRICES_FILE at a JSON file to override them without
# editing code: {"gpt-4o": [2.50, 10.00], "llama3.2:1b": [0, 0]}
# MODEL_PRICES_FILE=/etc/openwebui-exporter/prices.json

# Fallback $/1k-token rate for any model with no entry in the price table.
COST_PER_1K_INPUT_TOKENS=0
COST_PER_1K_OUTPUT_TOKENS=0
