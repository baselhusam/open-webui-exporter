OPENWEBUI_BASE_URL=http://localhost:3000
OPENWEBUI_API_KEY=changeme
POLL_INTERVAL_SECONDS=30
EXPORTER_PORT=9090

# Token prices live in pricing.py (a per-model rate table, $ per 1M tokens). It
# ships with published list prices for the SOTA models from the major providers
# (OpenAI, Anthropic, Google, xAI, DeepSeek, Qwen, Z.ai/GLM, Mistral) plus MOCK
# prices for the local Ollama models so the cost panels always have data.
#
# Override any of them with your own rates, no code edits needed:
#   MODEL_PRICES_CSV  — a price sheet (Excel-friendly). Copy model_prices.example.csv
#                       to model_prices.csv, edit it, and point here. CSV wins.
#   MODEL_PRICES_FILE — a JSON file: {"gpt-4o": [2.50, 10.00], "llama3.2:1b": [0, 0]}
# MODEL_PRICES_CSV=/etc/openwebui-exporter/model_prices.csv
# MODEL_PRICES_FILE=/etc/openwebui-exporter/prices.json
#
# For Docker Compose, MODEL_PRICES_CSV_HOST is the host path that gets mounted
# into the exporter container at /etc/openwebui-exporter/model_prices.csv.
# MODEL_PRICES_CSV_HOST=./model_prices.csv

# Fallback $/1k-token rate for any model with no entry in the price table.
COST_PER_1K_INPUT_TOKENS=0
COST_PER_1K_OUTPUT_TOKENS=0
