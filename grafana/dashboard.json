    {
      "id": 7,
      "title": "Exporter Health",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 20,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "#3FB68B"
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "HEALTHY",
                  "color": "#3FB68B",
                  "index": 0
                },
                "0": {
                  "text": "FAILING",
                  "color": "#E0655B",
                  "index": 1
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#E0655B",
                "value": null
              },
              {
                "color": "#3FB68B",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "wideLayout": true,
        "showPercentChange": false
      },
      "targets": [
        {
          "expr": "openwebui_exporter_scrape_success",
          "legendFormat": "Exporter Health",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "refId": "A"
        }
      ]
    },
