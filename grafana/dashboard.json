    {
      "id": 9,
      "title": "Provider Breakdown",
      "type": "piechart",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 8,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "ollama"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#4C8DFF"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "arena"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#8E7CF0"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "openai"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#37C2B9"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "pieType": "donut",
        "displayLabels": [
          "percent"
        ],
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value",
            "percent"
          ],
          "showLegend": true
        },
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "tooltip": {
          "mode": "single",
          "sort": "desc"
        }
      },
